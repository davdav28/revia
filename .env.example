# ------------------------------------------------------------------
# Boucle — variables d'environnement
# Copiez ce fichier en `.env.local` et remplissez les valeurs.
# Aucune valeur réelle ne doit être commitée.
# ------------------------------------------------------------------

# URL publique de l'application (sans slash final)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Base de données (Postgres managé : Supabase ou Neon) -----------
# Utilisée par Prisma. `DATABASE_URL` = connexion poolée (runtime),
# `DIRECT_URL` = connexion directe (migrations). [Phase 1]
DATABASE_URL="postgresql://user:password@host:5432/boucle?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/boucle"

# --- Authentification (Supabase Auth) ------------------------------ [Phase 1]
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""   # serveur uniquement, ne jamais exposer

# --- Messagerie SMS + Email (Brevo) -------------------------------- [Phase 3]
# Abstrait derrière l'interface MessagingProvider (Twilio en secours).
BREVO_API_KEY=""
BREVO_SMS_SENDER="Boucle"        # nom expéditeur SMS, <= 11 caractères
BREVO_EMAIL_SENDER="contact@boucle.fr"
BREVO_EMAIL_SENDER_NAME="Boucle"

# --- Paiement / abonnement du SaaS (Stripe) ------------------------ [Phase 5]
# Sans ces clés, l'abonnement fonctionne en mode démonstration (activation simulée).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# IDs de prix Stripe (Dashboard Stripe → Produits) : 3 plans × mensuel/annuel.
STRIPE_PRICE_ESSENTIEL_MONTHLY=""
STRIPE_PRICE_ESSENTIEL_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_MULTI_MONTHLY=""
STRIPE_PRICE_MULTI_ANNUAL=""
# Dépassement facturé à l'usage (Stripe Billing → Meters) : event_name du
# compteur de segments. Laisser vide pour ne pas facturer le dépassement.
STRIPE_OVERAGE_METER_EVENT=""

# --- Jobs planifiés (Vercel Cron) ---------------------------------- [Phase 2]
# Secret partagé pour authentifier l'appel du cron au scan quotidien.
CRON_SECRET=""
